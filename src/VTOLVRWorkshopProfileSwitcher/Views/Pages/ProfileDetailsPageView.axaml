<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:VTOLVRWorkshopProfileSwitcher.ViewModels.Pages"
             xmlns:vm="clr-namespace:VTOLVRWorkshopProfileSwitcher.ViewModels"
             xmlns:controls="clr-namespace:VTOLVRWorkshopProfileSwitcher.Views.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="VTOLVRWorkshopProfileSwitcher.Views.Pages.ProfileDetailsPageView"
             x:DataType="pages:ProfileDetailsPageViewModel"
             x:CompileBindings="False"
             mc:Ignorable="d">
  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <Border Classes="toolbar-panel" Padding="12">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
        <Button Content="&lt; Back" Classes="secondary-button" Command="{Binding Shell.BackToProfilesCommand}" />
        <Border Grid.Column="1" Classes="list-avatar" Margin="12,0,0,0" VerticalAlignment="Center">
          <materialIcons:MaterialIcon Kind="{Binding Profile.IconKind}" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock Grid.Column="2" Margin="12,0,0,0" Text="{Binding Profile.Name}" Classes="section-title" VerticalAlignment="Center" />
        <Button Grid.Column="3" Content="+ Add Mod" Classes="primary-button" Command="{Binding Shell.OpenAddModFlowCommand}" />
        <Button Grid.Column="4" Margin="8,0,0,0" Content="Reload + Check Deps" Classes="secondary-button" Command="{Binding Shell.ReloadProfileModsAndCheckDependenciesCommand}" />
        <Button Grid.Column="5" Margin="8,0,0,0" Content="{Binding Shell.PlayModdedButtonText}" Classes="success-button" IsEnabled="{Binding Shell.CanLaunchGame}" PointerEntered="OnLaunchButtonPointerEntered" PointerExited="OnLaunchButtonPointerExited" Command="{Binding Shell.PlayModdedCommand}" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="card-panel" Padding="12" Margin="0,12,0,0">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="1.3*,1.4*,1.1*,Auto,Auto">
          <TextBox Text="{Binding Shell.ProfileNameInput}" Watermark="Profile name" />
          <TextBox Grid.Column="1" Text="{Binding Shell.ProfileNotesInput}" Watermark="Profile notes" />
          <ComboBox Grid.Column="2"
                    Margin="8,0,0,0"
                    ItemsSource="{Binding Shell.ProfileIconOptions}"
                    SelectedItem="{Binding Shell.SelectedProfileIcon}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <materialIcons:MaterialIcon Kind="{Binding Kind}" Width="18" Height="18" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Grid.Column="3" Margin="8,0,0,0" Content="Rename / Save" Classes="primary-button" Command="{Binding Shell.RenameSelectedProfileCommand}" />
          <Button Grid.Column="4" Margin="8,0,0,0" Content="Apply Profile" Classes="secondary-button" Command="{Binding Shell.ApplySelectedProfileCommand}" />
        </Grid>
      </StackPanel>
    </Border>

    <Border Grid.Row="2" Classes="card-panel" Padding="12" Margin="0,12,0,0">
      <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="*,Auto">
        <TextBlock Text="Mods In Profile" Classes="section-title" />
        <CheckBox Grid.Column="1"
                  Content="Show Auto Dependencies"
                  IsChecked="{Binding Shell.ShowProfileDependencies}"
                  VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Margin="0,10,0,0" Text="{Binding Shell.ProfileModsSearchQuery}" Watermark="Search mods in this profile..." />
        <ScrollViewer Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Shell.FilteredProfileMods}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel ItemWidth="254" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ProfileModEntryViewModel">
                <controls:ModCardView ThumbnailImage="{Binding InstalledMod.ThumbnailImage}"
                                      Title="{Binding Name}"
                                      Subtitle="{Binding WorkshopId}"
                                      ShowToggle="False"
                                      ShowStatusText="True"
                                      StatusText="{Binding ProfileStateText}"
                                      DetailsCommand="{Binding $parent[UserControl].DataContext.Shell.SelectProfileModCommand}"
                                      DetailsCommandParameter="{Binding .}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <TextBlock Grid.Row="3" Text="{Binding Shell.ProfileUnderEditText}" Classes="text-muted" Margin="0,12,0,0" />
  </Grid>
</UserControl>
