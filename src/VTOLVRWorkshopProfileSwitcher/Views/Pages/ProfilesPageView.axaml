<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:VTOLVRWorkshopProfileSwitcher.ViewModels.Pages"
             xmlns:vm="clr-namespace:VTOLVRWorkshopProfileSwitcher.ViewModels"
             x:Class="VTOLVRWorkshopProfileSwitcher.Views.Pages.ProfilesPageView"
             x:DataType="pages:ProfilesPageViewModel"
             x:CompileBindings="False"
             mc:Ignorable="d">
  <Grid RowDefinitions="Auto,Auto,*">
    <Border Classes="toolbar-panel" Padding="12">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
        <TextBlock Text="Profiles" Classes="section-title" />
        <TextBox Grid.Column="1" Margin="12,0,0,0" Text="{Binding Shell.ProfileSearchQuery}" Watermark="Search profiles..." />
        <Button Grid.Column="2" Margin="8,0,0,0" Content="Import Package" Classes="secondary-button" Command="{Binding Shell.ImportProfilePackageCommand}" />
        <Button Grid.Column="3" Margin="8,0,0,0" Content="Export Selected" Classes="secondary-button" Command="{Binding Shell.ExportSelectedProfilePackageCommand}" />
        <Button Grid.Column="4" Margin="8,0,0,0" Content="Export All" Classes="secondary-button" Command="{Binding Shell.ExportAllProfilesPackageCommand}" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="card-panel" Padding="12" Margin="0,12,0,0">
      <Grid ColumnDefinitions="2*,2*,Auto,Auto">
        <TextBox Text="{Binding Shell.ProfileNameInput}" Watermark="Profile name" />
        <TextBox Grid.Column="1" Text="{Binding Shell.ProfileNotesInput}" Watermark="Notes" />
        <Button Grid.Column="2" Content="Save New Profile" Classes="primary-button" Command="{Binding Shell.SaveProfileCommand}" />
        <Button Grid.Column="3"
                Content="Delete Selected"
                Classes="warning-button"
                Command="{Binding Shell.DeleteSelectedProfileCommand}"
                CommandParameter="{Binding #ProfilesList.SelectedItems}" />
      </Grid>
    </Border>

    <Border Grid.Row="2" Classes="card-panel" Padding="12" Margin="0,12,0,0">
      <ListBox x:Name="ProfilesList"
               ItemsSource="{Binding Shell.FilteredProfiles}"
               SelectedItem="{Binding Shell.SelectedProfile}"
               SelectionMode="Multiple">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:ProfileItemViewModel">
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
              <Border Classes="card-panel" Padding="10" DoubleTapped="OnProfileItemDoubleTapped">
                <StackPanel Spacing="2">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Summary}" Classes="text-muted" />
                </StackPanel>
              </Border>
              <Button Grid.Column="1"
                      Margin="8,0,0,0"
                      VerticalAlignment="Center"
                      Width="74"
                      Content="Open"
                      Classes="secondary-button"
                      Command="{Binding $parent[UserControl].DataContext.Shell.OpenProfileDetailsCommand}"
                      CommandParameter="{Binding .}" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
  </Grid>
</UserControl>
