<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:VTOLVRWorkshopProfileSwitcher.ViewModels.Pages"
             x:Class="VTOLVRWorkshopProfileSwitcher.Views.Pages.SettingsPageView"
             x:DataType="pages:SettingsPageViewModel"
             x:CompileBindings="False"
             mc:Ignorable="d">
  <Grid RowDefinitions="Auto,*">
    <Border Classes="toolbar-panel" Padding="12">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBlock Text="Settings" Classes="section-title" />
          <TextBlock Text="Choose how the launcher behaves, which update channel it follows, and how VTOL VR starts."
                     Classes="text-muted"
                     TextWrapping="Wrap" />
        </StackPanel>
        <Border Grid.Column="1" Classes="card-panel" Padding="12,8" VerticalAlignment="Center">
          <StackPanel Spacing="2">
            <TextBlock Text="{Binding Shell.UpdateChannelText}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Shell.CurrentVersionText}" Classes="text-muted" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" Margin="0,12,0,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <Grid ColumnDefinitions="*,*">
          <Border Classes="card-panel" Padding="14">
            <Grid RowDefinitions="Auto,Auto,Auto,*">
              <StackPanel Spacing="4">
                <TextBlock Text="Overview" Classes="section-title" />
                <TextBlock Text="Current app identity and release channel at a glance."
                           Classes="text-muted"
                           TextWrapping="Wrap" />
              </StackPanel>

              <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,12,0,0">
                <Border Classes="toolbar-panel" Padding="12">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Version" Classes="text-muted" />
                    <TextBlock Text="{Binding Shell.CurrentVersionText}" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="{Binding Shell.CurrentVersionIdText, StringFormat=Build Id: {0}}" Classes="text-muted" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="toolbar-panel" Padding="12" Margin="10,0,0,0">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Channel" Classes="text-muted" />
                    <TextBlock Text="{Binding Shell.UpdateChannelText}" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="{Binding Shell.UpdateChannelDescription}" Classes="text-muted" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Grid>

              <Grid Grid.Row="2" ColumnDefinitions="*,*" Margin="0,12,0,0">
                <Border Classes="toolbar-panel" Padding="12">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Author" Classes="text-muted" />
                    <TextBlock Text="{Binding Shell.AppAuthor}" FontWeight="SemiBold" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="toolbar-panel" Padding="12" Margin="10,0,0,0">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Created" Classes="text-muted" />
                    <TextBlock Text="{Binding Shell.AppCreatedOn}" FontWeight="SemiBold" />
                  </StackPanel>
                </Border>
              </Grid>

              <Border Grid.Row="3" Classes="toolbar-panel" Padding="12" Margin="0,12,0,0">
                <TextBlock Text="{Binding Shell.UpdateStatusText}" Classes="text-muted" TextWrapping="Wrap" />
              </Border>
            </Grid>
          </Border>

          <Border Grid.Column="1" Classes="card-panel" Padding="14" Margin="12,0,0,0">
            <StackPanel Spacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="General" Classes="section-title" />
                <TextBlock Text="Small launcher preferences that affect everyday workflow."
                           Classes="text-muted"
                           TextWrapping="Wrap" />
              </StackPanel>

              <Border Classes="toolbar-panel" Padding="12">
                <StackPanel Spacing="10">
                  <CheckBox Content="Open Steam page after delete" IsChecked="{Binding Shell.OpenSteamPageAfterDelete}" />
                  <TextBlock Text="After a mod is removed from the launcher, Steam Workshop can open for follow-up management."
                             Classes="text-muted"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Classes="toolbar-panel" Padding="12">
                <StackPanel Spacing="10">
                  <TextBlock Text="VR Runtime" FontWeight="SemiBold" />
                  <TextBlock Text="Choose the launch target used when starting VTOL VR from the launcher."
                             Classes="text-muted"
                             TextWrapping="Wrap" />
                  <StackPanel Spacing="6">
                    <RadioButton Content="SteamVR (default)"
                                 GroupName="VrRuntime"
                                 IsChecked="{Binding Shell.IsSteamVrRuntime}"
                                 Command="{Binding Shell.SetVrRuntimeCommand}"
                                 CommandParameter="SteamVR" />
                    <RadioButton Content="Oculus"
                                 GroupName="VrRuntime"
                                 IsChecked="{Binding Shell.IsOculusRuntime}"
                                 Command="{Binding Shell.SetVrRuntimeCommand}"
                                 CommandParameter="Oculus" />
                    <RadioButton Content="OpenXR"
                                 GroupName="VrRuntime"
                                 IsChecked="{Binding Shell.IsOpenXrRuntime}"
                                 Command="{Binding Shell.SetVrRuntimeCommand}"
                                 CommandParameter="OpenXR" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </Grid>

        <Grid ColumnDefinitions="1.3*,1*">
          <Border Classes="card-panel" Padding="14">
            <StackPanel Spacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="Updates" Classes="section-title" />
                <TextBlock Text="Stable releases are the default. Beta mode enables prereleases and downgrade tools."
                           Classes="text-muted"
                           TextWrapping="Wrap" />
              </StackPanel>

              <Border Classes="toolbar-panel" Padding="12">
                <StackPanel Spacing="10">
                  <CheckBox Content="Auto install updates" IsChecked="{Binding Shell.AutoInstallUpdates}" />
                  <TextBlock Text="When a newer release is found, the launcher can prepare the installer flow."
                             Classes="text-muted"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Classes="toolbar-panel" Padding="12">
                <StackPanel Spacing="10">
                  <CheckBox Content="Include beta updates" IsChecked="{Binding Shell.IncludeBetaUpdates}" />
                  <TextBlock Text="Beta mode includes prereleases and enables downgrade tools. Beta installs always ask for confirmation before anything runs."
                             Classes="text-muted"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="Auto,Auto,*">
                <Button Content="Check For Update" Classes="primary-button" Command="{Binding Shell.CheckForUpdatesCommand}" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Install Update"
                        Classes="warning-button"
                        IsVisible="{Binding Shell.CanAutoInstallUpdate}"
                        Command="{Binding Shell.DownloadAndInstallUpdateCommand}" />
                <Border Grid.Column="2" Classes="toolbar-panel" Padding="12,8" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Shell.UpdateChannelDescription}"
                             Classes="text-muted"
                             TextWrapping="Wrap"
                             VerticalAlignment="Center" />
                </Border>
              </Grid>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Classes="card-panel" Padding="14" Margin="12,0,0,0">
            <StackPanel Spacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="Advanced Channel Tools" Classes="section-title" />
                <TextBlock Text="These controls only open up in beta mode."
                           Classes="text-muted"
                           TextWrapping="Wrap" />
              </StackPanel>

              <Border Classes="toolbar-panel" Padding="12">
                <TextBlock Text="{Binding Shell.DowngradeStatusText}"
                           Classes="text-muted" />
              </Border>

              <StackPanel Spacing="8" IsVisible="{Binding Shell.ShowDowngradeControls}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Manual Update" Classes="primary-button" Command="{Binding Shell.ManualUpdateCommand}" />
                  <Button Content="Load Downgrade List" Classes="secondary-button" Command="{Binding Shell.LoadDowngradeReleasesCommand}" />
                </StackPanel>

                <ComboBox MaxDropDownHeight="280"
                          ItemsSource="{Binding Shell.DowngradeReleaseOptions}"
                          SelectedItem="{Binding Shell.SelectedDowngradeRelease}"
                          DisplayMemberBinding="{Binding DisplayName}" />

                <Button Content="Install Selected Downgrade"
                        Classes="warning-button"
                        IsEnabled="{Binding Shell.CanInstallSelectedDowngrade}"
                        Command="{Binding Shell.InstallSelectedDowngradeCommand}" />
              </StackPanel>

              <Border Classes="toolbar-panel" Padding="12" IsVisible="{Binding Shell.ShowDowngradeHint}">
                <TextBlock Text="Enable 'Include beta updates' on the left to unlock prerelease browsing and downgrade installs."
                           Classes="text-muted"
                           TextWrapping="Wrap" />
              </Border>
            </StackPanel>
          </Border>
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
