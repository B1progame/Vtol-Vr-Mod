<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:VTOLVRWorkshopProfileSwitcher.ViewModels"
        xmlns:conv="clr-namespace:VTOLVRWorkshopProfileSwitcher.Converters"
        xmlns:pagesVm="clr-namespace:VTOLVRWorkshopProfileSwitcher.ViewModels.Pages"
        xmlns:pages="clr-namespace:VTOLVRWorkshopProfileSwitcher.Views.Pages"
        mc:Ignorable="d"
        x:Class="VTOLVRWorkshopProfileSwitcher.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Title="{Binding WindowTitle}"
        Width="1560"
        Height="940"
        MinWidth="1200"
        MinHeight="760"
        Background="{DynamicResource WindowBackgroundBrush}"
        Opacity="0">
  <Window.Transitions>
    <Transitions>
      <DoubleTransition Property="Opacity" Duration="0:0:0.24" Easing="CircularEaseOut" />
    </Transitions>
  </Window.Transitions>

  <Window.DataTemplates>
    <DataTemplate DataType="pagesVm:DashboardPageViewModel">
      <pages:DashboardPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:ProfilesPageViewModel">
      <pages:ProfilesPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:ServersPageViewModel">
      <pages:ServersPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:ProfileDetailsPageViewModel">
      <pages:ProfileDetailsPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:ServerDetailsPageViewModel">
      <pages:ServerDetailsPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:ModsPageViewModel">
      <pages:ModsPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:BackupsPageViewModel">
      <pages:BackupsPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:LogsPageViewModel">
      <pages:LogsPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:SettingsPageViewModel">
      <pages:SettingsPageView />
    </DataTemplate>
  </Window.DataTemplates>

  <Window.Resources>
    <conv:BoolToGridLengthConverter x:Key="DetailsWidthConverter" TruePixels="420" FalsePixels="0" />
  </Window.Resources>

  <Border Classes="shell-frame" Margin="14">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="272" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="{Binding IsDetailsOpen, Converter={StaticResource DetailsWidthConverter}}" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Classes="sidebar-panel" Padding="12" Margin="0,0,12,0">
      <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Margin="4,8,4,12" VerticalAlignment="Center" Spacing="8">
          <TextBlock Text="VTOL VR"
                     FontSize="26"
                     FontWeight="Bold" />
          <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
            <TextBlock Text="Workshop Switcher"
                       Classes="text-muted"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Border Grid.Column="1"
                    Classes="beta-chip"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    IsVisible="{Binding ShowSidebarBetaBadge}">
              <TextBlock Text="BETA" />
            </Border>
          </Grid>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="0">
          <Button Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsDashboardSelected}" Command="{Binding NavigateDashboardCommand}">
            <Grid ColumnDefinitions="Auto,*">
              <Border Classes="nav-icon"><TextBlock Text="&#xE80F;" /></Border>
              <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="Dashboard" VerticalAlignment="Center" />
            </Grid>
          </Button>
          <Button Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsProfilesSelected}" Command="{Binding NavigateProfilesCommand}">
            <Grid ColumnDefinitions="Auto,*">
              <Border Classes="nav-icon"><TextBlock Text="&#xE716;" /></Border>
              <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="Profiles" VerticalAlignment="Center" />
            </Grid>
          </Button>
          <Button Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsServersSelected}" Command="{Binding NavigateServersCommand}">
            <Grid ColumnDefinitions="Auto,*">
              <Border Classes="nav-icon"><TextBlock Text="&#xE703;" /></Border>
              <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="Servers" VerticalAlignment="Center" />
            </Grid>
          </Button>
          <Button Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsModsSelected}" Command="{Binding NavigateModsCommand}">
            <Grid ColumnDefinitions="Auto,*">
              <Border Classes="nav-icon"><TextBlock Text="&#xEA86;" /></Border>
              <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="Mods" VerticalAlignment="Center" />
            </Grid>
          </Button>
          <Button Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsBackupsSelected}" Command="{Binding NavigateBackupsCommand}">
            <Grid ColumnDefinitions="Auto,*">
              <Border Classes="nav-icon"><TextBlock Text="&#xE8B7;" /></Border>
              <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="Backups" VerticalAlignment="Center" />
            </Grid>
          </Button>
          <Button Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsLogsSelected}" Command="{Binding NavigateLogsCommand}">
            <Grid ColumnDefinitions="Auto,*">
              <Border Classes="nav-icon"><TextBlock Text="&#xE8A5;" /></Border>
              <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="Logs" VerticalAlignment="Center" />
            </Grid>
          </Button>
          <Button Classes="sidebar-item"
                  Classes.sidebar-item-active="{Binding IsSettingsSelected}"
                  Classes.update-alert="{Binding HasUpdateAvailable}"
                  Command="{Binding NavigateSettingsCommand}">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
              <Border Classes="nav-icon"><TextBlock Text="&#xE713;" /></Border>
              <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="Settings" VerticalAlignment="Center" />
              <Border Grid.Column="2"
                      Margin="8,0,0,0"
                      Classes="settings-warning-badge"
                      IsVisible="{Binding HasUpdateAvailable}"
                      VerticalAlignment="Center">
                <TextBlock Text="!" />
              </Border>
            </Grid>
          </Button>
        </StackPanel>

        <Border Grid.Row="2" Classes="sidebar-play-bar" Margin="0,16,0,0">
          <Grid ColumnDefinitions="*,52">
            <Button Content="{Binding SidebarPlayText}"
                    Classes="split-button-main"
                    Classes.stop-state="{Binding IsVtolRunning}"
                    IsEnabled="{Binding CanLaunchGame}"
                    Command="{Binding PlayModdedCommand}" />
            <Border Grid.Column="1" BorderBrush="{DynamicResource BorderDark}" BorderThickness="1,0,0,0">
              <Button x:Name="LaunchArrowButton" Classes="split-button-arrow" IsEnabled="{Binding CanOpenLaunchFlyout}">
                <TextBlock x:Name="LaunchArrowGlyph" Text="▼" Classes="split-button-arrow-glyph" />
                <Button.Flyout>
                  <Flyout Placement="TopEdgeAlignedRight" Opened="OnLaunchFlyoutOpened" Closed="OnLaunchFlyoutClosed">
                    <Border Classes="launch-flyout-panel" Margin="0,0,0,6">
                      <StackPanel Spacing="8" Width="176" DataContext="{Binding DataContext, ElementName=RootWindow}">
                        <Button Content="Play (Modded)" Classes="launch-flyout-button" Command="{Binding PlayModdedCommand}" />
                        <Button Content="Play (Vanilla)" Classes="launch-flyout-button" Command="{Binding PlayVanillaCommand}" />
                      </StackPanel>
                    </Border>
                  </Flyout>
                </Button.Flyout>
              </Button>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Column="1" Classes="main-content-panel" Padding="14">
      <ContentControl Content="{Binding CurrentPageViewModel}" />
    </Border>

    <Border Grid.Column="2"
            Classes="details-panel card-panel"
            Classes.details-panel-open="{Binding IsDetailsOpen}"
            Padding="12"
            IsVisible="{Binding IsDetailsOpen}">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="Details" Classes="section-title" />
          <Button Grid.Column="1" Content="Hide" Classes="secondary-button" Command="{Binding ToggleDetailsCommand}" />
        </Grid>

        <StackPanel Grid.Row="1" Spacing="2">
          <TextBlock Text="{Binding SelectedModTitle}" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" />
          <TextBlock Text="{Binding SelectedModAuthor, StringFormat=Author: {0}}" Classes="text-muted" />
          <TextBlock Text="{Binding SelectedModLastUpdated, StringFormat=Last Updated: {0}}" Classes="text-muted" />
        </StackPanel>

        <Border Grid.Row="2" Height="240" CornerRadius="8" Background="#223046" ClipToBounds="True">
          <Image Source="{Binding SelectedMod.ThumbnailImage}" Stretch="UniformToFill" />
        </Border>

        <Border Grid.Row="3" Classes="card-panel" Padding="10">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
            <TextBlock Text="Workshop ID:" />
            <TextBlock Grid.Column="1" Text="{Binding SelectedModWorkshopId}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="1" Text="Local Version:" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedModLocalVersion}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="2" Text="Remote Version:" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedModRemoteVersion}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="3" Text="Size:" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedModSize}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="4" Text="Status:" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedModStatus}" FontWeight="SemiBold" />
            <Border Grid.Row="5" Grid.ColumnSpan="2" Classes="status-badge" IsVisible="{Binding SelectedModHasUpdate}">
              <TextBlock Text="UPDATE AVAILABLE" />
            </Border>
          </Grid>
        </Border>

        <Border Grid.Row="4" Classes="card-panel" Padding="10" Margin="0,8,0,0" IsVisible="{Binding HasSelectedProfileModEntry}">
          <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
            <TextBlock Text="Active In Profile:" VerticalAlignment="Center" />
            <ToggleSwitch Grid.Column="1"
                          Margin="8,0,0,0"
                          HorizontalAlignment="Left"
                          IsChecked="{Binding SelectedProfileModActiveInProfile, Mode=TwoWay}" />
            <Button Grid.Column="2"
                    Margin="8,0,0,0"
                    Content="Remove From Profile"
                    Classes="warning-button"
                    Command="{Binding RemoveSelectedProfileModFromDetailsCommand}" />
            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="3"
                       Margin="0,8,0,0"
                       Classes="text-muted"
                       Text="Deactivating keeps the mod in this profile but excludes it when applying the profile." />
          </Grid>
        </Border>

        <Grid Grid.Row="6" ColumnDefinitions="*,*" Margin="0,8,0,0">
          <Button Content="Update" Classes="warning-button" Command="{Binding UpdateSelectedModCommand}" />
          <Button Grid.Column="1" Margin="8,0,0,0" Content="Open Workshop" Classes="secondary-button" Command="{Binding OpenSelectedModWorkshopCommand}" />
        </Grid>

        <Grid Grid.Row="7" ColumnDefinitions="*,*" Margin="0,8,0,0">
          <Button Content="Add To Profile"
                  Classes="primary-button"
                  Command="{Binding AddSelectedModToCurrentProfileCommand}"
                  CommandParameter="{Binding SelectedMod}" />
          <Button Grid.Column="1"
                  Margin="8,0,0,0"
                  Content="Delete Mod"
                  Classes="danger-button"
                  Command="{Binding DeleteModCommand}"
                  CommandParameter="{Binding SelectedMod}" />
        </Grid>
      </Grid>
    </Border>

    <Border Grid.ColumnSpan="3"
            Background="#E61A1D24"
            IsVisible="{Binding IsStartupLoading}"
            ZIndex="50">
      <Grid>
        <Border Width="540"
                MaxWidth="540"
                Padding="28"
                CornerRadius="14"
                Background="#F0222730"
                BorderBrush="#66B63B3B"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <StackPanel Spacing="18">
            <StackPanel HorizontalAlignment="Center" Spacing="10">
              <Border Width="84"
                      Height="84"
                      CornerRadius="18"
                      Background="#18283A"
                      BorderBrush="#33556F92"
                      BorderThickness="1"
                      Padding="10">
                <Image Source="/Assets/AppIcon-2.png" Stretch="Uniform" />
              </Border>
              <TextBlock Text="VTOL VR Switcher"
                         FontSize="28"
                         FontWeight="Bold"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding StartupStatusText}"
                         Classes="text-muted"
                         FontSize="15"
                         TextAlignment="Center"
                         HorizontalAlignment="Center" />
            </StackPanel>

            <ProgressBar Minimum="0"
                         Maximum="100"
                         Value="{Binding StartupProgressValue}"
                         Height="12"
                         CornerRadius="999" />

            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="{Binding StartupEtaText}"
                         Classes="text-muted"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding StartupProgressText}"
                         FontSize="20"
                         FontWeight="Bold"
                         VerticalAlignment="Center" />
            </Grid>

            <TextBlock Text="Large mod libraries can make startup take a little longer."
                       Classes="text-muted"
                       FontSize="13"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
  </Border>
</Window>
